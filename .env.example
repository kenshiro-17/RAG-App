# Shared
OPENAI_API_KEY=your_openai_api_key

# Backend
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/rag_app
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
EMBEDDING_MODEL=text-embedding-3-small
RESPONSE_MODEL=gpt-4.1-mini
CHUNK_TOKENS=450
OVERLAP_TOKENS=80
EMBEDDING_BATCH_SIZE=64
RETRIEVAL_TOP_K=8
RETRIEVAL_VECTOR_WEIGHT=0.65
RETRIEVAL_KEYWORD_WEIGHT=0.35
RETRIEVAL_KEYWORD_LANGUAGE=english
RATE_LIMIT_CAPACITY=25
RATE_LIMIT_REFILL_PER_SEC=0.5
CORS_ORIGINS=http://localhost:3000

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/data/storage
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Observability
SENTRY_DSN=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
